# Copy to `.env` and fill in real values. `.env` is gitignored — NEVER commit secrets.
# Also add every one of these to the Trigger.dev dashboard (Project -> Environment Variables),
# for BOTH staging and prod — missing dashboard vars are the #1 cause of production failures.

# --- Trigger.dev ---
# Project ref from cloud.trigger.dev -> your project (looks like proj_xxxxxxxx).
TRIGGER_PROJECT_REF=
# Production secret key (to trigger prod tasks). Dashboard -> Production env -> API Keys ->
# "secret key" (starts with tr_prod_...). Keep this secret — it can trigger your tasks.
TRIGGER_SECRET_KEY=

# --- Slack delivery (two recipients) ---
# 1. Create an app at https://api.slack.com/apps -> Bot Token scopes: chat:write, files:write,
#    im:write. Install to workspace -> copy the "Bot User OAuth Token" (xoxb-...).
# 2. Targets below can be a channel ID (C…) OR a user ID (U…) for a private DM. For user DMs the
#    bot opens the conversation automatically (needs im:write); no invite required.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_OPERATOR=
SLACK_CHANNEL_MILA=

# --- Supabase (rolling state: format-dedup log + agent market_knowledge) ---
# Create a free project at https://supabase.com -> Project Settings -> API.
# URL = "Project URL"; KEY = the "service_role" secret (NOT the anon key) so tasks can write.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Price research APIs (so the agent doesn't burn tokens web-searching prices) ---
# CardTrader: https://www.cardtrader.com -> account -> API -> generate a JWT/bearer token.
CARDTRADER_API_TOKEN=
# eBay: https://developer.ebay.com -> create a Production app. The task mints its own OAuth token.
# EBAY_APP_ID  = the Production "App ID (Client ID)".
# EBAY_API_KEY = the Production "Cert ID (Client Secret)".
EBAY_APP_ID=
EBAY_API_KEY=
